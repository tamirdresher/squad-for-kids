++/**
++ * Rework command ΓÇö Analyze PR rework rate (the 5th DORA metric)
++ *
++ * Measures what percentage of code changes require revision after
++ * initial review. Uses `gh` CLI to fetch merged PR data.
++ */
++
++import { execFile } from 'node:child_process';
++import { promisify } from 'node:util';
++import { fatal } from '../core/errors.js';
++import { BOLD, RESET, DIM, GREEN, YELLOW, RED } from '../core/output.js';
++import {
++  calculatePrRework,
++  calculateReworkSummary,
++  type PrInfo,
++  type PrReview,
++  type PrCommit,
++  type PrReworkResult,
++  type ReworkSummary,
++} from '../core/rework.js';
++import { ghAvailable } from '../core/gh-cli.js';
++
++const execFileAsync = promisify(execFile);
++
++export interface ReworkFlags {
++  days: number;
++  limit: number;
++  json: boolean;
++}
++
++function parseFlags(args: string[]): ReworkFlags {
++  const daysIdx = args.indexOf('--days');
++  const days = daysIdx !== -1 && args[daysIdx + 1]
++    ? parseInt(args[daysIdx + 1]!, 10)
++    : 30;
++
++  const limitIdx = args.indexOf('--limit');
++  const limit = limitIdx !== -1 && args[limitIdx + 1]
++    ? parseInt(args[limitIdx + 1]!, 10)
++    : 20;
++
++  const json = args.includes('--json');
++
++  if (isNaN(days) || days < 1) fatal('--days must be a positive number');
++  if (isNaN(limit) || limit < 1) fatal('--limit must be a positive number');
++
++  return { days, limit, json };
++}
++
++function colorReworkRate(rate: number): string {
++  if (rate <= 15) return `${GREEN}${rate}${RESET}`;
++  if (rate <= 30) return `${YELLOW}${rate}${RESET}`;
++  return `${RED}${rate}${RESET}`;
++}
++
++function printReworkReport(
++  results: PrReworkResult[],
++  summary: ReworkSummary,
++  lookbackDays: number,
++): void {
++  console.log(`${BOLD}Summary (${summary.totalPrs} PRs, last ${lookbackDays} days)${RESET}`);
++  console.log(`${'ΓöÇ'.repeat(50)}`);
++  console.log(`  Average rework rate:   ${colorReworkRate(summary.avgReworkRate ?? 0)}%`);
++  console.log(
++    `  PRs with rework:       ${summary.prsWithRework ?? 0}/${summary.totalPrs} (${Math.round(((summary.prsWithRework ?? 0) / summary.totalPrs) * 100)}%)`,
++  );
++  console.log(`  Rejection rate:        ${summary.rejectionRate ?? 0}%`);
++  console.log(`  Avg review cycles:     ${summary.avgReviewCycles ?? 0}`);
++  console.log(`  Total rework commits:  ${summary.totalReworkCommits ?? 0}/${summary.totalCommits ?? 0}`);
++  if (summary.avgReworkTimeHours != null) {
++    console.log(`  Avg rework time:       ${summary.avgReworkTimeHours}h`);
++  }
++  console.log();
++
++  // Per-PR breakdown
++  console.log(`${BOLD}Per-PR Breakdown${RESET}`);
++  console.log(`${'ΓöÇ'.repeat(80)}`);
++
++  for (const r of results) {
++    const rateLabel = colorReworkRate(r.reworkRate);
++    const changeLabel = r.hadChangesRequested ? `${YELLOW}ΓÜæ${RESET}` : ' ';
++    console.log(
++      `  #${String(r.number).padEnd(5)} ${rateLabel}% rework  ${r.reviewCycles} cycles  ${changeLabel}  ${DIM}${r.title.substring(0, 40)}${RESET}`,
++    );
++  }
++  console.log();
++
++  // Interpretation guide
++  const rate = summary.avgReworkRate ?? 0;
++  if (rate <= 15) {
++    console.log(`${GREEN}Γ£ô${RESET} Rework rate is healthy. Code quality and review process are strong.`);
++  } else if (rate <= 30) {
++    console.log(`${YELLOW}ΓÜá${RESET} Moderate rework rate. Consider improving PR descriptions or pre-review checks.`);
++  } else {
++    console.log(`${RED}Γ£ù${RESET} High rework rate. Review process may need attention ΓÇö consider smaller PRs, clearer specs, or pair reviews.`);
++  }
++  console.log();
++}
++
++/**
++ * Run the rework analysis command.
++ */
++export async function runRework(args: string[]): Promise<void> {
++  const flags = parseFlags(args);
++
++  // Verify gh CLI is available
++  if (!(await ghAvailable())) {
++    fatal('gh CLI not found ΓÇö install from https://cli.github.com');
++  }
++
++  const sinceDate = new Date(Date.now() - flags.days * 86_400_000)
++    .toISOString()
++    .split('T')[0]!;
++
++  if (!flags.json) {
++    console.log(`\n${BOLD}≡ƒôè Rework Rate Analysis${RESET}`);
++    console.log(
++      `${DIM}Analyzing merged PRs from the last ${flags.days} days (limit: ${flags.limit})...${RESET}\n`,
++    );
++  }
++
++  // Fetch merged PRs
++  let prs: PrInfo[];
++  try {
++    const { stdout } = await execFileAsync('gh', [
++      'pr', 'list',
++      '--state', 'merged',
++      '--limit', String(flags.limit),
++      '--search', `merged:>=${sinceDate}`,
++      '--json', 'number,title,author,mergedAt,additions,deletions,changedFiles',
++    ], { timeout: 30_000 });
++    prs = JSON.parse(stdout || '[]') as PrInfo[];
++  } catch (err) {
++    fatal(`Failed to fetch PRs: ${(err as Error).message}`);
++  }
++
++  if (prs.length === 0) {
++    if (flags.json) {
++      console.log(JSON.stringify({ prs: [], summary: { totalPrs: 0 } }, null, 2));
++    } else {
++      console.log(`${DIM}No merged PRs found in the last ${flags.days} days.${RESET}`);
++    }
++    return;
++  }
++
++  // Analyze each PR for rework
++  const results: PrReworkResult[] = [];
++  for (const pr of prs) {
++    try {
++      const { stdout } = await execFileAsync('gh', [
++        'pr', 'view', String(pr.number),
++        '--json', 'reviews,commits',
++      ], { timeout: 15_000 });
++      const detail = JSON.parse(stdout) as { reviews?: PrReview[]; commits?: PrCommit[] };
++      const rework = calculatePrRework(pr, detail.reviews ?? [], detail.commits ?? []);
++      results.push(rework);
++    } catch {
++      // Skip PRs we can't fetch details for
++    }
++  }
++
++  // Calculate aggregate metrics
++  const summary = calculateReworkSummary(results);
++
++  if (flags.json) {
++    console.log(JSON.stringify({ prs: results, summary }, null, 2));
++  } else {
++    printReworkReport(results, summary, flags.days);
++  }
++}
