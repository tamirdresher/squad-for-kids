node_modules/

# Telegram bot token (secret — never commit)
telegram-bot-token

# Squad Tier 1: Transaction memory (raw, high-volume, may contain PII)
.squad/orchestration-log/
.squad/log/
.squad/sessions/
.squad/digests/[0-9]*.md
.squad/digests/[0-9]*-*.md
.squad/digests/triage/*.jsonl
.squad/raw-agent-output.md
.squad/run-output.md

# Squad Tier 2 & 3: Always committed (do NOT ignore)
# .squad/digests/archive/     — QMD digests
# .squad/digests/dream/       — Dream reports
# .squad/decisions/            — Team decisions
# .squad/skills/               — Permanent skills
# .squad/templates/            — Templates
# .squad/agents/               — Agent config

# Upstream synced repos (local clones, not committed)
.squad/_upstream_repos/

# .NET build artifacts
bin/
obj/

# Generated audio files — stored in OneDrive/cloud, not Git
*-audio.mp3
*-audio.wav
*.mp3
*.wav

# Squad build artifacts — regenerated on clone
.squad/tools/**/bin/
.squad/tools/**/obj/

# Squad vector DB index — regenerated from markdown source
.squad/.db/
.squad/chroma/

# Docs build output
_site/


.nano-banana-config.json

.playwright-cli/

# --- Secrets hardening (issue #666) ---
# Environment files (never commit actual .env, only .env.example)
*.env
.env.*
!.env.example

# Leaked secret screenshots or dumps
*secret*.png
*secret*.jpg
*secret*.txt
*credential*.png
*credential*.jpg
*credential*.txt

# Config files that may contain tokens
*-config.json

# Cryptographic material
*.key
*.pem
