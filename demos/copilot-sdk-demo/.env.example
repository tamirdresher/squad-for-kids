# ── GitHub Models (recommended for demos) ─────────────────────────────────────
# Get a token at https://github.com/settings/tokens (no scopes required)
GITHUB_TOKEN=github_pat_your_token_here

# ── Alternative: OpenAI API ────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key

# ── Alternative: Azure OpenAI ─────────────────────────────────────────────────
# GITHUB_TOKEN=your-azure-openai-key
# AI_ENDPOINT=https://your-resource.openai.azure.com/
# COPILOT_MODEL=gpt-4o

# ── Model selection ────────────────────────────────────────────────────────────
# Default: gpt-4o-mini (faster, cheaper — great for quick demos)
# Use gpt-4o for deeper, more nuanced debates
# COPILOT_MODEL=gpt-4o
