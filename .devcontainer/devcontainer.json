{
  "name": "tamresearch1 — Development Container",
  "image": "mcr.microsoft.com/devcontainers/universal:latest",
  
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "humao.rest-client",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "files.exclude": {
          "**/.git": false
        }
      }
    }
  },

  "forwardPorts": [3000, 5000, 8080, 8888, 18888],
  "portsAttributes": {
    "3000": {
      "label": "Dev Server",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "Backend API",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "HTTP",
      "onAutoForward": "notify"
    },
    "8888": {
      "label": "Jupyter/Aspire",
      "onAutoForward": "notify"
    },
    "18888": {
      "label": "Aspire Dashboard",
      "onAutoForward": "notify"
    }
  },

  "remoteUser": "codespace",
  "remoteEnv": {
    "NODE_ENV": "development"
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "npm run dev 2>/dev/null || true",

  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/codespace/.ssh,readonly"
  ],

  "updateContentCommand": "npm install",
  
  "initializeCommand": ".devcontainer/init.sh"
}
