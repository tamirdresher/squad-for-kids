+def log(msg, level="INFO"):
+    ts = datetime.now().strftime("%H:%M:%S")
+    icon = {"INFO": "ℹ️", "OK": "✅", "FAIL": "❌", "WARN": "⚠️", "TRY": "🔄"}.get(level, "")
+    print(f"[{ts}] {icon} {msg}")
+    results.append({"time": ts, "level": level, "msg": msg})
