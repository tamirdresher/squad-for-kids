# =============================================================================
# Squad Environment Variables — .env.example
# =============================================================================
# Copy this file to $env:USERPROFILE\.squad\.env and fill in actual values.
# NEVER commit actual secrets to git. This file documents required variables only.
# Run scripts/setup-secrets.ps1 to load secrets into your session.
# =============================================================================

# Google Gemini API key — get from https://aistudio.google.com/apikey
# Also stored in Windows Credential Manager as 'google-gemini-api-key'
GOOGLE_API_KEY=

# Teams webhook URL for Neelix notifications
# File-based: stored at $env:USERPROFILE\.squad\teams-webhook.url
TEAMS_WEBHOOK_URL=

# Telegram bot token (if using telegram integration)
# Also available from .nano-banana-config.json (gitignored)
TELEGRAM_BOT_TOKEN=

# GitHub PAT — managed by 'gh auth login', not typically set manually
# GITHUB_TOKEN=

# Squad email password — stored in Windows Credential Manager as 'squad-email-outlook'
# Retrieved programmatically; do NOT set in .env unless Credential Manager unavailable
# SQUAD_EMAIL_PASSWORD=
