    "tags": {
      "value": {
        "Environment": "Pre-Production",
        "Project": "FedRAMP Dashboard",
        "Owner": "infrastructure-team@contoso.com",
        "CostCenter": "IT-Security",
        "SLA": "99.5%"
      }
