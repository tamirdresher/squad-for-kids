{
  "mcpServers": {
    "azure-devops": {
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "msazure"
      ],
      "tools": [
        "*"
      ]
    },
    "bitwarden": {
      "type": "local",
      "command": "node",
      "args": [
        "C:/temp/mcp-server/dist/index.js"
      ],
      "tools": [
        "squad_store",
        "squad_get",
        "squad_list",
        "squad_audit",
        "status",
        "list",
        "get",
        "generate"
      ]
    },
    "EXAMPLE-trello": {
      "command": "npx",
      "args": [
        "-y",
        "@trello/mcp-server"
      ],
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}"
      }
    }
  }
}
