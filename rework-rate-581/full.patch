++/**
++ * Rework Rate ΓÇö Unit tests for calculation logic.
++ *
++ * Tests the pure calculation functions in core/rework.ts.
++ * No gh CLI calls needed ΓÇö all data is synthetic.
++ */
++
++import { describe, it, expect } from 'vitest';
++import {
++  calculatePrRework,
++  calculateReworkSummary,
++  type PrInfo,
++  type PrReview,
++  type PrCommit,
++  type PrReworkResult,
++} from '../packages/squad-cli/src/cli/core/rework.js';
