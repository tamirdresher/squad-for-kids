{
  "version": 1,
  "schedules": [
    {
      "id": "ralph-heartbeat",
      "name": "Ralph Heartbeat",
      "description": "Run Squad triage every 5 minutes",
      "enabled": true,
      "trigger": {
        "type": "interval",
        "intervalSeconds": 300
      },
      "task": {
        "type": "workflow",
        "ref": ".github/workflows/squad-heartbeat.yml",
        "event": "workflow_dispatch"
      },
      "providers": [
        "local-polling",
        "github-actions"
      ],
      "retry": {
        "maxAttempts": 2,
        "backoffSeconds": 30
      },
      "timeout": 600,
      "notifyOnFailure": [
        "teams"
      ],
      "tags": [
        "triage",
        "ralph"
      ]
    },
    {
      "id": "daily-digest",
      "name": "Daily Digest",
      "description": "Send team digest of yesterday's activity",
      "enabled": true,
      "trigger": {
        "type": "cron",
        "expression": "0 8 * * *",
        "timezone": "UTC"
      },
      "task": {
        "type": "workflow",
        "ref": ".github/workflows/squad-daily-digest.yml",
        "event": "workflow_dispatch"
      },
      "providers": [
        "github-actions",
        "local-fallback"
      ],
      "retry": {
        "maxAttempts": 3,
        "backoffSeconds": 60
      },
      "timeout": 1800,
      "notifyOnFailure": [
        "teams"
      ],
      "tags": [
        "monitoring",
        "digest"
      ]
    },
    {
      "id": "daily-rp-briefing",
      "name": "Daily BasePlatformRP Briefing",
      "description": "Generate and send comprehensive RP status report at 9 AM (local)",
      "enabled": true,
      "trigger": {
        "type": "cron",
        "expression": "0 7 * * 1-5",
        "timezone": "Asia/Jerusalem"
      },
      "task": {
        "type": "script",
        "command": ".squad/scripts/daily-rp-briefing.ps1 -SkipWeekends",
        "shell": "powershell"
      },
      "providers": [
        "local-polling"
      ],
      "retry": {
        "maxAttempts": 2,
        "backoffSeconds": 60
      },
      "timeout": 600,
      "notifyOnFailure": [
        "teams"
      ],
      "tags": [
        "monitoring",
        "briefing",
        "rp"
      ]
    },
    {
      "id": "daily-adr-check",
      "name": "Daily ADR Channel Monitor",
      "description": "Monitor IDP ADR Notifications Teams channel for new/updated ADRs. Read-only — NEVER post to the channel. Report actionable items to Tamir via Teams webhook.",
      "enabled": true,
      "trigger": {
        "type": "cron",
        "expression": "0 7 * * 1-5",
        "timezone": "UTC"
      },
      "task": {
        "type": "copilot",
        "instruction": "Run the daily ADR channel check: Query IDP ADR Notifications channel via WorkIQ for new/updated ADRs in the last 24h. Identify items needing Tamir's attention (pending reviews, decisions, blockers). Send summary to Teams webhook. NEVER comment on the ADR channel or any ADR.",
        "scriptRef": ".squad/scripts/daily-adr-check.ps1"
      },
      "providers": [
        "local-polling",
        "copilot-agent"
      ],
      "retry": {
        "maxAttempts": 2,
        "backoffSeconds": 120
      },
      "timeout": 900,
      "notifyOnFailure": [
        "teams"
      ],
      "tags": [
        "monitoring",
        "adr",
        "idp"
      ],
      "metadata": {
        "issue": "#198",
        "owner": "picard",
        "channelUrl": "https://teams.microsoft.com/l/channel/19%3A6d7865cdcaab4446a800c51dfc76cbb0%40thread.tacv2/IDP%20ADR%20Notifications?groupId=25cc215a-8287-4155-a51d-833837db2864&tenantId=72f988bf-86f1-41af-91ab-2d7cd011db47",
        "readOnly": true,
        "neverComment": true
      }
    },
    {
      "id": "weekly-upstream-sync",
      "name": "Weekly Upstream Sync",
      "description": "Sync upstream repos every Monday at 2 AM UTC",
      "enabled": true,
      "trigger": {
        "type": "cron",
        "expression": "0 2 * * 1",
        "timezone": "UTC"
      },
      "task": {
        "type": "copilot",
        "instruction": "Sync all upstream repos: check for new issues, PRs, discussions"
      },
      "providers": [
        "copilot-agent"
      ],
      "retry": {
        "maxAttempts": 1,
        "backoffSeconds": 0
      },
      "timeout": 3600,
      "notifyOnFailure": [
        "teams",
        "issue-comment"
      ],
      "tags": [
        "sync",
        "upstream"
      ]
    },
    {
      "id": "teams-message-monitor",
      "name": "Teams Message Monitor",
      "description": "Monitor Teams channels for actionable messages directed at the squad. Silent review with smart filtering - only surface items requiring Tamir's attention.",
      "enabled": true,
      "trigger": {
        "type": "interval",
        "intervalSeconds": 1200
      },
      "task": {
        "type": "copilot",
        "instruction": "Use WorkIQ (workiq-ask_work_iq tool) to scan recent Teams messages from the last 30 minutes. Focus on: direct mentions of Tamir or the squad, review requests, action items, urgent items, decisions needing input. Silently evaluate each item - only create a GitHub issue or notification if Tamir specifically needs to act. Use teams-monitor skill workflow for filtering and issue creation. Avoid spam - be selective.",
        "scriptRef": ".squad/scripts/teams-monitor-check.ps1"
      },
      "providers": [
        "local-polling"
      ],
      "retry": {
        "maxAttempts": 2,
        "backoffSeconds": 60
      },
      "timeout": 600,
      "notifyOnFailure": [
        "teams"
      ],
      "tags": [
        "monitoring",
        "teams",
        "communication"
      ],
      "metadata": {
        "issue": "#215",
        "owner": "belanna",
        "checkInterval": "20 minutes",
        "smartFiltering": true,
        "silentReview": true
      }
    },
    {
      "enabled": true,
      "retry": {
        "backoffSeconds": 0,
        "maxAttempts": 1
      },
      "tags": [
        "monitoring",
        "news",
        "research"
      ],
      "description": "Scan HackerNews and Reddit for relevant AI, .NET, Kubernetes, and developer tools news",
      "timeout": 300,
      "providers": [
        "local-polling"
      ],
      "name": "Tech News Scanner",
      "id": "tech-news-scan",
      "notifyOnFailure": [
        "teams"
      ],
      "task": {
        "command": "node scripts/tech-news-scanner.js",
        "type": "script"
      },
      "trigger": {
        "timezone": "Asia/Jerusalem",
        "type": "cron",
        "expression": "0 7 * * 1-5"
      }
    },
    {
      "id": "weekly-retro",
      "description": "Review all work done this week, read issue comments and discussions, identify what Tamir liked/disliked, retrospect on squad behavior, improve rules/directives/tooling proactively",
      "trigger": {
        "description": "Every Friday at 14:00 UTC (4 PM Israel)",
        "expression": "0 14 * * 5",
        "timezone": "UTC",
        "type": "cron"
      },
      "providers": [
        "local-polling"
      ],
      "task": {
        "action": "retrospective",
        "agent": "picard",
        "type": "agent"
      },
      "name": "Weekly Squad Retrospective",
      "enabled": true
    },
    {
      "id": "whatsapp-check",
      "description": "Open WhatsApp Web via Playwright, check for messages from wife, report via Teams if she needs something. READ ONLY - never send messages.",
      "trigger": {
        "description": "Every 2 hours on weekdays",
        "intervalSeconds": 7200,
        "type": "interval"
      },
      "providers": [
        "local-polling"
      ],
      "task": {
        "action": "whatsapp-monitor",
        "agent": "kes",
        "type": "agent"
      },
      "name": "WhatsApp Family Check",
      "enabled": true
    }
  ],
  "defaults": {
    "retryMaxAttempts": 2,
    "retryBackoffSeconds": 60,
    "timeout": 1800,
    "notifyOnFailure": [
      "teams"
    ]
  },
  "notificationChannels": {
    "teams": {
      "webhookUrl": "${TEAMS_WEBHOOK_URL}",
      "format": "adaptive-card"
    },
    "issue-comment": {
      "repo": "tamirdresher_microsoft/tamresearch1",
      "labels": [
        "squad:ralph",
        "automation"
      ]
    }
  }
}
